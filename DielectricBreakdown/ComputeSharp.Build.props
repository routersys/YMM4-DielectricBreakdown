<Project>
	<PropertyGroup Condition="'$(MSBuildProjectName)' == 'ComputeSharp' or '$(MSBuildProjectName)' == 'ComputeSharp.Core'">
		<BaseOutputPath>$(MSBuildProjectDirectory)\bin\DielectricBreakdown\</BaseOutputPath>
		<BaseIntermediateOutputPath>$(MSBuildProjectDirectory)\obj\DielectricBreakdown\</BaseIntermediateOutputPath>
		<MSBuildProjectExtensionsPath>$(MSBuildProjectDirectory)\obj\</MSBuildProjectExtensionsPath>
		<DefaultItemExcludes>$(DefaultItemExcludes);$(MSBuildProjectDirectory)\obj\**</DefaultItemExcludes>
	</PropertyGroup>
	<PropertyGroup Condition="'$(MSBuildProjectName)' == 'ComputeSharp'">
		<AssemblyName>DielectricBreakdown.ComputeSharp</AssemblyName>
	</PropertyGroup>
	<PropertyGroup Condition="'$(MSBuildProjectName)' == 'ComputeSharp.Core'">
		<AssemblyName>DielectricBreakdown.ComputeSharp.Core</AssemblyName>
	</PropertyGroup>
</Project>
